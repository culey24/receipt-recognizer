OCR_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_MODELS=nvidia/nemotron-nano-12b-v2-vl:free,google/gemini-2.5-flash
OPENROUTER_AUTO_FALLBACK=true
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_SITE_NAME=CBAM OCR Local

# CORS — update with your Vercel domain for production
# Example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
JOB_TTL_SECONDS=86400

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=receipt_recognizer
MONGO_JOBS_COLLECTION=ocr_jobs
MONGO_CASES_COLLECTION=ocr_cases
MONGO_FUEL_MAPPING_COLLECTION=fuel_mappings
MONGO_EMISSION_FACTOR_COLLECTION=emission_factors
MONGO_PORT=27017

# Phase 2 default
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./data/uploads

# Phase 3 (MinIO)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=receipt-images
MINIO_REGION=us-east-1
GRID_EMISSION_FACTOR_VN=0.6592
CARBON_PRICE_TICKERS=CO2.L,^ICEEUA
CARBON_PRICE_FALLBACK_EUR=
FX_RATE_TICKER=EURVND=X
FX_RATE_FALLBACK_EUR_VND=
REPORT_STORAGE_PATH=./data/reports

API_PORT=8000
FRONTEND_PORT=5173

# ── Production overrides (Fly.io) ────────────────────────────────────────────
# Set these via `fly secrets set KEY=value` — do NOT commit real values here.
#
# REDIS_HOST=your-upstash-host.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your_upstash_token
#
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/receipt_recognizer
#
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT_URL=https://your-bucket.r2.cloudflarestorage.com   (Cloudflare R2)
# MINIO_ACCESS_KEY=your_r2_access_key
# MINIO_SECRET_KEY=your_r2_secret_key
# MINIO_BUCKET=receipt-images
#
# ALLOWED_ORIGINS=https://your-app.vercel.app
