# Local dev
VITE_API_BASE_URL=http://localhost:8000

# Production (Vercel → Settings → Environment Variables for Production).
# Must be the public HTTPS API URL (e.g. https://xxxx.up.railway.app).
# If unset at build time, the bundle uses localhost and the browser shows NetworkError.
# VITE_API_BASE_URL=https://xxxx.up.railway.app
